/* pages/index/index.wxss */
.container {
  padding: 0;
  height: 100vh;
  background: linear-gradient(180deg, #FF7762 0%, #FF6B66 50%, #FD9A65 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 20rpx;
  width: 100%;
}

.title-container {
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 5;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
  position: relative;
}

.title::before,
.title::after {
  content: "";
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background-size: contain;
  background-repeat: no-repeat;
}

.title::before {
  left: -80rpx;
  top: 5rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23FFD700"><path d="M12 2L14.1 8.1H20.6L15.2 12L17.4 18.2L12 14.3L6.6 18.2L8.8 12L3.4 8.1H9.9L12 2Z"/></svg>');
}

.title::after {
  right: -80rpx;
  top: 5rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23FFD700"><path d="M12 2L14.1 8.1H20.6L15.2 12L17.4 18.2L12 14.3L6.6 18.2L8.8 12L3.4 8.1H9.9L12 2Z"/></svg>');
}

/* 飘扬的标题样式 */
.subtitle-box {
  position: relative;
  width: 400rpx;
  height: 60rpx;
  overflow: visible;
  margin: 10rpx auto 30rpx;
}

.subtitle-flag {
  position: relative;
  background-color: #E54B4B;
  color: white;
  font-size: 30rpx;
  padding: 12rpx 20rpx;
  border-radius: 6rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
  animation: flagWave 3s ease-in-out infinite;
}

@keyframes flagWave {
  0% {
    transform: perspective(400px) rotateX(0deg);
  }
  25% {
    transform: perspective(400px) rotateX(5deg) scale(1.01);
  }
  50% {
    transform: perspective(400px) rotateX(0deg);
  }
  75% {
    transform: perspective(400px) rotateX(-5deg) scale(0.99);
  }
  100% {
    transform: perspective(400px) rotateX(0deg);
  }
}

.subtitle {
  font-size: 32rpx;
  color: #fff;
  opacity: 0.9;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: left;
  width: 100%;
}

/* 主要内容区域 */
.main-wrapper {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 2;
}

.preview-container {
  width: 350rpx;
  height: 350rpx;
  background-color: transparent;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 12rpx 24rpx rgba(0,0,0,0.25);
  overflow: hidden;
  margin-right: 30rpx;
  border: none;
  padding: 0;
  transition: all 0.3s ease;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.3s ease;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.action-btn {
  width: 200rpx;
  height: 80rpx;
  background-color: #fff;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  margin: 0;
  padding: 0;
  line-height: 1.2;
  font-weight: normal;
}

.action-btn-primary {
  background-color: #FF5E62;
  color: #fff;
}

/* 头像框选择区域 */
.tab-container {
  width: 96%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 0;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.15);
  overflow: hidden;
  position: relative;
  z-index: 2;
}

.tabs {
  display: flex;
  justify-content: space-between;
  padding: 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.08);
  position: relative;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.3s;
  overflow: hidden;
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(255,94,98,0.05), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.tab-item.active {
  color: #FF5E62;
  font-weight: bold;
  background-color: rgba(255, 94, 98, 0.05);
}

.tab-item.active::before {
  opacity: 1;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: #FF5E62;
  border-radius: 4rpx 4rpx 0 0;
  animation: tabLineIn 0.3s ease forwards;
}

@keyframes tabLineIn {
  from {
    width: 0;
    left: 50%;
  }
  to {
    width: 50%;
    left: 25%;
  }
}

.frames-scroll {
  width: 100%;
  background-color: #fff;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}

.frames-list {
  display: flex;
  flex-wrap: nowrap;
  justify-content: flex-start;
  width: 100%;
  transition: all 0.3s ease;
}

.frame-item {
  width: 170rpx;
  height: 170rpx;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
  margin-right: 28rpx;
  border-radius: 12rpx;
  background-color: transparent;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
}

.frame-item.active {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(229, 75, 75, 0.25);
}

.frame-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(45deg, rgba(255,255,255,0), rgba(255,255,255,0.1), rgba(255,255,255,0));
  opacity: 0;
  transition: opacity 0.3s;
}

.frame-item.active::after {
  opacity: 1;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.frame-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: all 0.3s ease;
}

/* 装饰元素 */
.decoration-left {
  position: absolute;
  left: 20rpx;
  top: 120rpx;
  width: 100rpx;
  height: 200rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 60" fill="%23FFD700" opacity="0.5"><path d="M12 2C9 15 15 25 5 35 15 45 9 55 12 58"/><path d="M18 8C15 18 20 26 12 34 20 42 15 52 18 55" stroke="%23FFD700" fill="none"/></svg>');
  background-repeat: no-repeat;
  opacity: 0.6;
  z-index: 1;
}

.decoration-right {
  position: absolute;
  right: 20rpx;
  top: 120rpx;
  width: 100rpx;
  height: 200rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 60" fill="%23FFD700" opacity="0.5"><path d="M12 2C15 15 9 25 19 35 9 45 15 55 12 58"/><path d="M6 8C9 18 4 26 12 34 4 42 9 52 6 55" stroke="%23FFD700" fill="none"/></svg>');
  background-repeat: no-repeat;
  opacity: 0.6;
  z-index: 1;
}

.action-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  margin-bottom: 60rpx;
}

.primary-btn {
  background: #E54B4B;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  width: 100%;
  margin-bottom: 20rpx;
}

.secondary-btn {
  background: #FFD25A;
  color: #333;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  width: 100%;
}

.tips-container {
  width: 94%;
  background-color: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.tips-title::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  background-color: #FF5E62;
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-content text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.footer {
  width: 100%;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 40rpx;
}

/* 隐藏不需要的原始样式 */
.tips-container, .footer, .section-title, .action-container, .frames-container, .logo, .subtitle, .main-content {
  display: none;
}

/* 增加一个装饰元素填充底部空白 */
.decoration-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.05));
  z-index: 1;
} 