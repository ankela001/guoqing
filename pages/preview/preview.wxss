/* pages/preview/preview.wxss */
.container {
  padding: 40rpx 30rpx;
  background-color: #f8f8f8;
}

.preview-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.avatar-preview {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  margin: 0 auto 40rpx;
  overflow: hidden;
  background-color: #f0f0f0;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.action-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.share-btn {
  background: #E54B4B;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

.back-btn {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

.tips-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.tips-steps {
  margin-bottom: 30rpx;
}

.step {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.step-num {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #FFD25A;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #333;
  font-weight: bold;
  margin-right: 20rpx;
}

.step-text {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.tips-images {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.tip-image {
  width: 48%;
  height: 200rpx;
  border-radius: 10rpx;
} 