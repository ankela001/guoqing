<view class="container">
  <view class="preview-container">
    <view class="preview-title">头像预览</view>
    
    <view class="avatar-preview">
      <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFit"></image>
    </view>
    
    <view class="action-container">
      <button class="share-btn" open-type="share">分享给朋友</button>
      <button class="back-btn" bindtap="goBack">返回首页</button>
    </view>
  </view>
  
  <view class="tips-container">
    <view class="tips-title">设置方法</view>
    <view class="tips-steps">
      <view class="step">
        <text class="step-num">1</text>
        <text class="step-text">打开手机相册，找到刚保存的头像</text>
      </view>
      <view class="step">
        <text class="step-num">2</text>
        <text class="step-text">打开微信，进入"我"页面</text>
      </view>
      <view class="step">
        <text class="step-num">3</text>
        <text class="step-text">点击头像，选择"编辑"</text>
      </view>
      <view class="step">
        <text class="step-num">4</text>
        <text class="step-text">从相册中选择刚保存的头像</text>
      </view>
    </view>
    
    <view class="tips-images">
      <image class="tip-image" src="/static/image/addTips/fav-1.jpg" mode="aspectFit"></image>
      <image class="tip-image" src="/static/image/addTips/fav-2.jpg" mode="aspectFit"></image>
    </view>
  </view>
</view> 